# Copy this file to .env.local before running the app:
# cp .env.example .env.local

# Supabase browser client (public anon credentials only).
# For local Supabase, run `npm run supabase:start` and copy the API URL and anon key
# from the CLI output. The local API URL is usually http://127.0.0.1:54321.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server clients (never expose the service role key to browser code).
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI quote extraction.
# Set OPENAI_API_KEY for live extraction. OPENAI_MODEL is required whenever live
# extraction is enabled; this example is an operator-selected default only.
# Verify the model name is available for your OpenAI account before deployment.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Local/demo operations.
# Required for POST /api/demo/reset and `npm run demo:reset`.
# Enables the full fixture reseed endpoint for Playwright and operator workflows.
ENABLE_DEMO_RESET=true

# Enables the user-facing button that clears quote activity only.
# Safe only for an isolated demo database.
ENABLE_DEMO_ACTIVITY_RESET=true

# Optional Playwright override when testing against an already-running app.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
